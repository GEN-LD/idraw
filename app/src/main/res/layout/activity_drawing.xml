<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- Left Toolbar -->
    <ScrollView
        android:id="@+id/toolbar_scroll"
        android:layout_width="64dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/toolbar_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_toolbar_panel"
            android:gravity="center_horizontal"
            android:paddingVertical="8dp"
            android:paddingHorizontal="4dp">

            <!-- Back -->
            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="4dp" />

            <!-- Brush type buttons -->
            <ImageButton
                android:id="@+id/btn_pen"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_pen"
                android:contentDescription="Pen"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <ImageButton
                android:id="@+id/btn_eraser"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_eraser"
                android:contentDescription="Eraser"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="4dp" />

            <!-- Size buttons -->
            <ImageButton
                android:id="@+id/btn_size_s"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_size_s"
                android:contentDescription="Size S"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <ImageButton
                android:id="@+id/btn_size_m"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_size_m"
                android:contentDescription="Size M"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <ImageButton
                android:id="@+id/btn_size_l"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_size_l"
                android:contentDescription="Size L"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="4dp" />

            <!-- Undo / Clear -->
            <ImageButton
                android:id="@+id/btn_undo"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_undo"
                android:contentDescription="Undo"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <ImageButton
                android:id="@+id/btn_clear"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_clear"
                android:contentDescription="Clear"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Drawing Canvas -->
    <com.gen.idraw.view.DrawingView
        android:id="@+id/drawing_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:layout_constraintStart_toEndOf="@id/toolbar_scroll"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/rv_colors"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Right Color Panel -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_colors"
        android:layout_width="60dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_toolbar_panel"
        android:paddingHorizontal="4dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
