<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- Left Toolbar -->
    <ScrollView
        android:id="@+id/toolbar_scroll"
        android:layout_width="64dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/toolbar_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_toolbar_panel"
            android:gravity="center_horizontal"
            android:paddingVertical="8dp"
            android:paddingHorizontal="4dp">

            <!-- Back -->
            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="4dp" />

            <!-- Brush type buttons -->
            <ImageButton
                android:id="@+id/btn_pencil"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_pencil"
                android:contentDescription="Pencil"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <ImageButton
                android:id="@+id/btn_pen"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_pen"
                android:contentDescription="Pen"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <ImageButton
                android:id="@+id/btn_crayon"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_crayon"
                android:contentDescription="Crayon"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <ImageButton
                android:id="@+id/btn_eraser"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_eraser"
                android:contentDescription="Eraser"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="4dp" />

            <!-- Size slider -->
            <com.google.android.material.slider.Slider
                android:id="@+id/slider_brush_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="1"
                android:valueTo="12"
                android:stepSize="1"
                app:thumbColor="@color/primary"
                app:trackColorActive="@color/primary"
                app:trackHeight="4dp"
                android:layout_marginBottom="4dp" />

            <!-- Size preview -->
            <View
                android:id="@+id/view_size_preview"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@color/brush_red"
                android:layout_marginBottom="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="4dp" />

            <!-- Undo / Redo / Clear -->
            <ImageButton
                android:id="@+id/btn_undo"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_undo"
                android:contentDescription="Undo"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <ImageButton
                android:id="@+id/btn_redo"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_redo"
                android:contentDescription="Redo"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <ImageButton
                android:id="@+id/btn_clear"
                android:layout_width="@dimen/toolbar_button_size"
                android:layout_height="@dimen/toolbar_button_size"
                android:src="@drawable/ic_clear"
                android:contentDescription="Clear"
                android:background="@drawable/bg_brush_button"
                android:padding="8dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Drawing Canvas -->
    <com.gen.idraw.view.DrawingView
        android:id="@+id/drawing_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:layout_constraintStart_toEndOf="@id/toolbar_scroll"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/color_panel_scroll"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Right Color Panel -->
    <ScrollView
        android:id="@+id/color_panel_scroll"
        android:layout_width="48dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@drawable/bg_toolbar_panel">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingVertical="8dp"
            android:paddingHorizontal="4dp">

            <!-- Color picker -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_colors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
