<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="horizontal"
    android:background="@color/background">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_coloring_mode"
        style="@style/IdrawButton.Home.Coloring"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/home_button_margin"
        android:text="@string/coloring_mode" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_drawing_mode"
        style="@style/IdrawButton.Home.Drawing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/drawing_mode" />

</LinearLayout>
